default_platform(:ios)

APP_ID = 'top.fancytech.gamebox'
TEAM_ID = 'C9DKTHSYYB'
PROFILE = 'match AppStore top.fancytech.gamebox'

platform :ios do
  def asc_key
    app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_KEY_CONTENT'], # base64 of the .p8
      is_key_content_base64: true,
      in_house: false
    )
  end

  # ONE-TIME (run first, via workflow_dispatch): register the bundle id on the
  # Developer Portal AND create the App Store Connect record so TestFlight has a
  # destination. `produce`'s devcenter path uses legacy Apple-ID login (no 2FA
  # in CI), so we register the bundle id ourselves via the App Store Connect API
  # (which the API key supports), then let produce create just the ITC record.
  desc 'Register bundle id + create the App Store Connect record (run once)'
  lane :create_app do
    require 'spaceship'
    require 'base64'

    # Authenticate Spaceship with the App Store Connect API key (no Apple-ID /
    # 2FA), so everything works in a non-interactive CI shell.
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key: Base64.decode64(ENV['ASC_KEY_CONTENT'])
    )

    # 1. Register the bundle id on the Developer Portal.
    if Spaceship::ConnectAPI::BundleId.all.any? { |b| b.identifier == APP_ID }
      UI.success("Bundle id #{APP_ID} already registered")
    else
      Spaceship::ConnectAPI::BundleId.create(name: 'GameBox', identifier: APP_ID, platform: 'IOS')
      UI.success("Registered bundle id #{APP_ID}")
    end

    # 2. Create the App Store Connect app record (TestFlight destination).
    if Spaceship::ConnectAPI::App.find(APP_ID)
      UI.success("App Store Connect record for #{APP_ID} already exists")
    else
      Spaceship::ConnectAPI::App.create(
        name: 'GameBox',
        version_string: '1.0',
        sku: 'gamebox-ios',
        primary_locale: 'en-US',
        bundle_id: APP_ID,
        platforms: ['IOS']
      )
      UI.success("Created App Store Connect record for #{APP_ID}")
    end
  end

  # ONE-TIME (run second): create the distribution cert (reused if it already
  # exists in the match repo) + an appstore profile for this bundle id, stored
  # encrypted in the private match repo over SSH.
  desc 'Initialize signing in the match repo (run once, after create_app)'
  lane :init_signing do
    setup_ci
    match(type: 'appstore', app_identifier: APP_ID, api_key: asc_key, readonly: false)
  end

  desc 'Build and upload to TestFlight'
  lane :beta do
    api_key = asc_key
    setup_ci
    match(type: 'appstore', app_identifier: APP_ID, api_key: api_key, readonly: true)
    # Flutter defaults to automatic signing; switch to manual with the
    # match-provisioned profile so the ephemeral runner reuses the stored cert.
    update_code_signing_settings(
      path: 'ios/Runner.xcodeproj',
      use_automatic_signing: false,
      team_id: TEAM_ID,
      code_sign_identity: 'Apple Distribution',
      bundle_identifier: APP_ID,
      profile_name: PROFILE,
      targets: ['Runner']
    )
    build_app(
      workspace: 'ios/Runner.xcworkspace', # CocoaPods workspace
      scheme: 'Runner',                    # Flutter's default iOS scheme
      export_method: 'app-store',
      export_options: {
        signingStyle: 'manual',
        provisioningProfiles: {
          APP_ID => PROFILE
        }
      }
    )
    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: true)
  end
end
